#!/bin/bash

# Git hooks run from the repository root, so we need to cd to dart_lmdb2
cd dart_lmdb2

# Get the version from pubspec.yaml
VERSION=$(grep "^version:" pubspec.yaml | cut -d' ' -f2)

# Create the version.dart file
cat > lib/src/version.dart << EOF
// This file is auto-generated. Do not edit manually.
// Generated by .git/hooks/pre-commit
const String dartLmdb2Version = '$VERSION';
EOF

# Add the file to the commit
git add lib/src/version.dart

echo "Updated dart_lmdb2/lib/src/version.dart to version $VERSION"